<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
 

  <link rel="stylesheet" href="tyylit.css">
</head>

<body>

<div class="topnav" id="myTopnav">
  <a href="index.html" class="active">Etusivu</a>
  <a href="digicafe.html">Digi Cafe</a>
  <a href="palaveri.html">Palaveri</a>
  <a href="tyopaikat.html">Työpaikat</a>
</div>


<div id="vastaus"></div>
<div id="palaveri"></div>


<script>


fetch('https://raw.githubusercontent.com/maij4vo/json/refs/heads/main/digicafe')

// Muunnetaan JSON-muotoon
.then(function (response) {
    return response.json();
})

// Käsitellään data
.then(function (responseJson) {
    kerro(responseJson);
})

// Virhetilanteessa
.catch(function (error) {
    document.getElementById("vastaus").innerHTML =
    "<p>Tietoa ei pystytä hakemaan</p>";
});


function kerro(data) {

    var teksti = "";

    // Yritys
    teksti += "<h1>" + data.yritys + "</h1>";

    // Yhteystiedot
    teksti += "<h3>Yhteystiedot</h3>";
    teksti += "<p>"
        + data.yhteystiedot.osoite + "<br>"
        + data.yhteystiedot.puhelin + "<br>"
        + data.yhteystiedot.email
        + "</p>";

    // Tuotteet
    teksti += "<h3>Tuotteet</h3><ul>";
    for (var i = 0; i < data.tuotteet.length; i++) {
        teksti += "<li>" + data.tuotteet[i] + "</li>";
    }
    teksti += "</ul>";

    // Henkilökunta
    teksti += "<h3>Henkilökunta</h3><ul>";
    for (var i = 0; i < data.henkilokunta.length; i++) {
        teksti += "<li>"
            + data.henkilokunta[i].nimi + " - "
            + data.henkilokunta[i].titteli
            + "</li>";
    }
    teksti += "</ul>";

    document.getElementById("vastaus").innerHTML = teksti;
}



  </script>

</body>
</html>
